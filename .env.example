# ── Root .env — used by docker-compose ────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.

# ── ngrok (dev overlay only) ───────────────────────────────────────────────────
# Required when using docker-compose.dev.yml overlay (Electron or local sharing).
# Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# ── Security secrets [REQUIRED] ────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -hex 32

# Secret for signing JWT tokens — must be a long random string in production
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# AES-256-GCM key for encrypting stored PATs and API keys
# WARNING: changing this will invalidate all existing encrypted secrets in the DB
ENCRYPTION_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── URLs [REQUIRED] ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# - Local Docker (HTTP):  http://localhost
# - Custom domain (HTTPS): https://your-domain.com
# - ngrok tunnel: https://<id>.ngrok-free.app
FRONTEND_URL=http://localhost
