# ── ngrok ──────────────────────────────────────────────────────────────────────
# Required. Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# ── Backend ────────────────────────────────────────────────────────────────────
# Strong secret for express-session cookie signing
SESSION_SECRET=change-me-to-a-long-random-string

# URL that the backend's CORS policy whitelists.
# In production this should be your ngrok public URL, e.g. https://abc123.ngrok-free.app
# For local Docker usage http://localhost works fine.
FRONTEND_URL=http://localhost
