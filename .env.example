# ── ngrok ──────────────────────────────────────────────────────────────────────
# Required. Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# ── Backend ────────────────────────────────────────────────────────────────────
# Secret for signing JWT tokens — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# URL that the backend's CORS policy whitelists AND determines secure-cookie mode.
# - Local Docker (HTTP):  http://localhost
# - ngrok (HTTPS):        https://<your-ngrok-id>.ngrok-free.app
# Update this to your current ngrok URL when using ngrok, then redeploy.
FRONTEND_URL=http://localhost

# AES-256-GCM key for encrypted PAT storage — change in production
ENCRYPTION_KEY=change-this-to-a-long-random-string-in-production
