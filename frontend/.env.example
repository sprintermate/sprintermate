# ── Frontend .env — used by `npm run dev` ─────────────────────────────────────
# Copy this file to frontend/.env.local for local development.

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Backend URLs ───────────────────────────────────────────────────────────────
# Server-side (SSR) backend URL — used by Next.js server components
# In Docker this is the internal service name; in dev it's localhost
BACKEND_URL=http://localhost:4000

# Public backend URL — used by the browser (client-side fetches)
# Leave empty in Docker (nginx proxies /api/* to backend automatically)
# Set to http://localhost:4000 for local development
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Set to "true" in production deployments to hide AI provider settings UI
NEXT_PUBLIC_IS_PRODUCTION_AI=false

# Public canonical site URL — used for SEO (sitemap, canonical URLs, Open Graph tags)
# Set this to your production domain in production deployments
NEXT_PUBLIC_SITE_URL=https://sprintermate.com
