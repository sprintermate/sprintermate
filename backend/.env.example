PORT=4000
FRONTEND_URL=http://localhost:3000

# Microsoft Entra ID (Azure AD) OAuth
# App must be configured as multi-tenant in Azure portal (Supported account types:
# "Accounts in any organizational directory and personal Microsoft accounts")
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/callback

# Session
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# PAT encryption key — used to AES-256-GCM encrypt stored Personal Access Tokens
# Set to any long random string; changing it will invalidate existing encrypted PATs
ENCRYPTION_KEY=vvLp3aIF1YIKllLxeS79zWARxInaaJoi5lLAm9kQKWc=
