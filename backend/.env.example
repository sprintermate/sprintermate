# ── Backend .env — used by `npm run dev` ──────────────────────────────────────
# Copy this file to backend/.env for local development.

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to backend/ directory)
DB_PATH=data/scrum-poker.db

# ── Security secrets [REQUIRED] ────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -hex 32

# Secret for signing JWT tokens
JWT_SECRET=change-this-to-a-long-random-string-in-production

# AES-256-GCM key for encrypting stored PATs and API keys
# WARNING: changing this will invalidate all existing encrypted secrets in the DB
ENCRYPTION_KEY=change-this-to-a-long-random-string-in-production

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000
